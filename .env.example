# ========================================
# LangChain SMC Trading Agent — Standalone
# คัดลอกไฟล์นี้เป็น .env แล้วแก้ไขค่า
# ========================================

# --- จำเป็น ---
OPENAI_API_KEY=sk-your-openai-key-here

# gpt-4o = แม่นยำ, gpt-4o-mini = ประหยัด
OPENAI_MODEL=gpt-4o-mini

# --- ตัวเลือก ---
# MT5 Symbol (default: XAUUSD)
MT5_SYMBOL=XAUUSD
